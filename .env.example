# Database
DATABASE_URL="file:./prisma/dev.db"

# Auth — generate with: openssl rand -base64 64
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# Anthropic AI — get from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Google Drive Service Account (account: haianlabs@gmail.com)
# Create a service account at https://console.cloud.google.com, enable Drive API,
# share the target folder with the service account email
GDRIVE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GDRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GDRIVE_FOLDER_ID="your-google-drive-folder-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Veritamom"
